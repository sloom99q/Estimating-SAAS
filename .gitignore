# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
*.local

# Bun
bun.lockb
# Stack is Bun-only — npm/yarn lockfiles are noise from accidental tool use.
package-lock.json
yarn.lock

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# TypeScript incremental build cache
node_modules/.tmp/
*.tsbuildinfo

# Env
.env
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test / coverage
coverage/

# Sprint-2 takeoff pipeline — never commit binary fixtures or runtime data.
# Sprint-4: glob the dir contents (not the dir itself) so the small text
# groundtruth.json can be re-included with a negation.
apps/api/fixtures/**
!apps/api/fixtures/
!apps/api/fixtures/plot4357.groundtruth.json
# Sprint-7 S7-4: bbox-layout JSON fixtures are small (<100KB) text and
# drive the spatial parser's TDD test. Commit them.
!apps/api/fixtures/bbox/
!apps/api/fixtures/bbox/*.json
apps/api/data/
apps/api/tmp/
