# Copy to `.env` and adjust. Only variables prefixed with VITE_ are exposed to the client.
# In Phase 1 the app runs entirely on mock services, so none of these are required yet —
# they document the seam the real backend (Phase 2) will plug into.

# Base URL of the future REST/GraphQL API. Empty = use in-memory mock services.
VITE_API_URL=

# Human-readable app name shown in the shell. Falls back to "Estimator".
VITE_APP_NAME=Estimator
