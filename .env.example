# Copy to `.env` and adjust. Only variables prefixed with VITE_ are exposed to the client.
#
# Phase 8A wires the SPA up to the Bun + Prisma + SQLite API (apps/api).
# Leaving VITE_API_URL blank falls back to the legacy in-browser mock services.

# Base URL of the Estimator API. Must include the protocol; no trailing slash.
VITE_API_URL=http://localhost:4000

# Human-readable app name shown in the shell. Falls back to "Estimator".
VITE_APP_NAME=Estimator
