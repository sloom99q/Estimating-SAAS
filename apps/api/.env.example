# Estimator API — Bun + Prisma + SQLite (Phase 8A)
# Copy to apps/api/.env

# SQLite database file. Lives outside src so the SPA tree never accidentally
# touches it. Path is relative to apps/api/prisma when Prisma loads it.
DATABASE_URL="file:../data/app.db"

# JWT signing secret. ROTATE BEFORE DEPLOY.
# Generate something stronger with: openssl rand -hex 32
JWT_SECRET="dev-only-secret-rotate-me-before-deploy"

# JWT access-token TTL (in seconds). Default 12h.
JWT_TTL_SECONDS=43200

# Port the API listens on.
PORT=4000

# Origin allowed via CORS (the Vite dev server).
CORS_ORIGIN="http://localhost:5173"
