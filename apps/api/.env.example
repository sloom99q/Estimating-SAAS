# Estimator API — Phase 9 Sprint 2 (PostgreSQL + takeoff pipeline)
# Copy to apps/api/.env

# ----------------------------------------------------------------------------
# DATABASE_URL is the only required runtime coupling. Pick one:
#
#   Neon (zero-install, recommended)  →  https://neon.tech
#     Copy the *pooled* connection string with ?sslmode=require
#     DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
#
#   Local Postgres (no Docker)
#     brew install postgresql@16 && brew services start postgresql@16
#     createdb estimator_dev
#     DATABASE_URL="postgresql://localhost:5432/estimator_dev"
#
#   docker-compose (shipped at repo root)
#     docker compose up -d postgres
#     DATABASE_URL="postgresql://estimator:estimator@localhost:5432/estimator"
#
# DIRECT_URL is used ONLY by `prisma migrate`. Neon's pooler does not support
# advisory locks; migrations need a session-pinned (non-pooled) connection.
# For Neon: same string with "-pooler" removed from the host.
# For everything else (local pg, docker, supabase): same as DATABASE_URL.
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://localhost:5432/estimator_dev"
DIRECT_URL="postgresql://localhost:5432/estimator_dev"

# JWT signing secret. ROTATE BEFORE DEPLOY.
#   openssl rand -hex 32
JWT_SECRET="dev-only-secret-rotate-me-before-deploy"

# JWT access-token TTL (in seconds). Default 12h.
JWT_TTL_SECONDS=43200

# Port the API listens on.
PORT=4000

# Origin allowed via CORS (the Vite dev server).
CORS_ORIGIN="http://localhost:5173"

# ----------------------------------------------------------------------------
# Sprint 2 additions
# ----------------------------------------------------------------------------

# Filesystem path for the dev BlobStore driver. Keys live under
#   org/{orgId}/projects/{projectId}/documents/{docId}/...
# The S3-compatible driver (Sprint 3+) keeps an identical key format so
# nothing in the application changes when we flip the driver.
BLOB_ROOT="./data/blobs"

# Background-worker tick interval (ms). Lowered = snappier UX during dev.
WORKER_TICK_MS=1500

# Architect-review fix: any RUNNING job older than this is reaped (requeued
# if attempts<MAX, else terminal FAILED with reason 'timeout'). Default 10min.
JOB_TIMEOUT_MS=600000

# Hide /api/jobs/_test in production. Default: enabled outside production.
ENABLE_TEST_ROUTES=true

# Anthropic — server-side only, never exposed to the browser.
# When empty, the AI client returns DETERMINISTIC STUBS so the pipeline runs
# offline (used in Sprint 2 acceptance). Drop in a real key to switch to live
# calls; the model is the only other knob.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ----------------------------------------------------------------------------
# Prerequisites (NOT env vars, but called out here so you only audit once):
#
#   - PDF tooling for INGEST:
#       brew install poppler                # pdfinfo / pdffonts / pdftotext / pdftoppm
#
#   - Test fixture (NOT committed):
#       Place the source drawing PDF at:
#         apps/api/fixtures/plot4357.pdf
#       Sprint-2 acceptance runs against this file.
# ----------------------------------------------------------------------------
