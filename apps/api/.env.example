# Estimator API — Phase 9 Sprint 1 (PostgreSQL)
# Copy to apps/api/.env

# ----------------------------------------------------------------------------
# DATABASE_URL is the only required coupling. Pick one:
#
#   Neon (zero-install, recommended)
#     1. Create a free Postgres at https://neon.tech
#     2. Copy the pooled connection string with ?sslmode=require
#     DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
#
#   Supabase (zero-install alternative)
#     DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
#
#   Local install (no Docker)
#     brew install postgresql@16 && brew services start postgresql@16
#     createdb estimator_dev
#     DATABASE_URL="postgresql://localhost:5432/estimator_dev"
#
#   docker-compose (shipped at repo root as a fallback)
#     docker compose up -d postgres
#     DATABASE_URL="postgresql://estimator:estimator@localhost:5432/estimator"
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://localhost:5432/estimator_dev"

# JWT signing secret. ROTATE BEFORE DEPLOY.
# openssl rand -hex 32
JWT_SECRET="dev-only-secret-rotate-me-before-deploy"

# JWT access-token TTL (in seconds). Default 12h.
JWT_TTL_SECONDS=43200

# Port the API listens on.
PORT=4000

# Origin allowed via CORS (the Vite dev server).
CORS_ORIGIN="http://localhost:5173"

# Filesystem path for the dev BlobStore driver. Keys live under
#   org/{orgId}/projects/{projectId}/documents/{docId}/...
# The S3-compatible driver (Sprint 2) keeps an identical key format so
# nothing in the application changes when we flip the driver.
BLOB_ROOT="./data/blobs"

# Background-worker tick interval (ms). Lowered = snappier UX during dev.
WORKER_TICK_MS=1500

# Anthropic API key. Server-side ONLY — never exposed to the browser.
# Sprint 2 starts using it; Sprint 1 ships scaffolding only.
ANTHROPIC_API_KEY=""
