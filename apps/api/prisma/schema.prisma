// Sprint-1 schema (Phase 9). PostgreSQL is now the live source of truth.
// SQLite has been retired — the previous app.db is migrated by
// `apps/api/scripts/migrate-sqlite-to-postgres.ts`.
//
// Conventions (per architect rulings, ADR-010):
//   - cuid() PKs
//   - @db.Timestamptz(6) on every DateTime
//   - Decimal @db.Decimal(p, s) for money/qty on NEW takeoff models
//     (Sprint 2+). Existing 8A/8B Float columns stay Float for now to keep
//     /materials and /suppliers wire-shape stable; promotion to Decimal is a
//     follow-up cleanup, not Sprint 1.
//   - organizationId on every tenant-scoped row; composite uniques scope by org.
//   - Soft-delete via deletedAt; audit createdAt/updatedAt.
//   - Role enum uses the repo's 4-role vocabulary (owner/admin/estimator/viewer).
//
// ADR-009 (8B pricing model supersedes spec §2):
//   - MaterialSupplierPrice + PriceSnapshot are retained as the authoritative
//     procurement schema. Supplier gains `creditLimitAed`.
//
// ADR-010 (schema source of truth):
//   - apps/api/prisma/schema.prisma is now the LIVE schema; the root
//     prisma/schema.prisma stays as the long-term reference.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // App connections use the pooled DSN (cheap, scalable).
  url       = env("DATABASE_URL")
  // Migrations need session-scoped state (advisory locks) which Neon's pooler
  // does not support. Point DIRECT_URL at the non-pooled host; the runtime
  // never touches it. Locally this is just DATABASE_URL with "-pooler" removed.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum MembershipRole {
  owner
  admin
  estimator
  viewer
}

// Sprint-2 enums (takeoff pipeline).

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

// Brief lists "WIGHT" between DOOR and FLOOR_FINISH — that's a typo for
// WINDOW (the only plausible counterpart to DOOR in a fit-out catalogue).
// Using WINDOW; flag for architect review at sprint close.
enum TakeoffCategory {
  ROOM
  DOOR
  WINDOW
  FLOOR_FINISH
  WALL_FINISH
  CEILING
  SCREED
  PAINT
  PLASTER
  BLOCKWORK
  WATERPROOFING
  METAL
  GRC
  JOINERY
  SANITARY
  EXTERNAL
  STRUCTURE_PROV
  MEP_PROV
  OTHER
}

enum TakeoffBasis {
  MEASURED
  DERIVED
  VISUAL
  PARAMETRIC
  PLACEHOLDER
}

enum TakeoffStatus {
  AI
  EDITED
  APPROVED
}

enum ValidationSeverity {
  ERROR
  WARN
  INFO
}

// ---------------------------------------------------------------------------
// Identity & tenancy
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String
  passwordHash String
  avatarUrl    String?
  isSuperAdmin Boolean   @default(false)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  memberships Membership[]

  @@map("users")
}

model Organization {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  defaultCurrency String    @default("AED")
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime? @db.Timestamptz(6)

  memberships            Membership[]
  projects               Project[]
  spaces                 Space[]
  materials              Material[]
  suppliers              Supplier[]
  materialSupplierPrices MaterialSupplierPrice[]
  priceSnapshots         PriceSnapshot[]
  jobs                   Job[]
  usage                  Usage?
  // Sprint-2 takeoff pipeline.
  documents              Document[]
  sheets                 Sheet[]
  takeoffItems           TakeoffItem[]
  validationFlags        ValidationFlag[]
  corrections            Correction[]

  @@map("organizations")
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(estimator)
  status         String         @default("active")
  invitedAt      DateTime       @default(now()) @db.Timestamptz(6)
  joinedAt       DateTime?      @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("memberships")
}

// ---------------------------------------------------------------------------
// Estimation domain (8A)
// ---------------------------------------------------------------------------

model Project {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  clientName     String
  location       String
  type           String
  status         String    @default("lead")
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime? @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  spaces          Space[]
  documents       Document[]
  takeoffItems    TakeoffItem[]
  validationFlags ValidationFlag[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("projects")
}

model Space {
  id                String    @id @default(cuid())
  organizationId    String
  projectId         String
  name              String
  length            Float
  width             Float
  height            Float
  floorMaterialId   String?
  wallMaterialId    String?
  ceilingMaterialId String?
  // Sprint-2 additive columns. Nullable / defaulted so the wire shape of the
  // existing /api/spaces endpoint stays stable for the SPA — fields appear in
  // responses only after EXTRACT_ROOMS has populated them.
  code              String?
  floor             String?
  areaM2            Decimal?  @db.Decimal(10, 2)
  source            String    @default("manual")  // 'manual' | 'takeoff'
  confidence        Int?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([organizationId])
  @@index([organizationId, projectId, source])
  @@map("spaces")
}

model Material {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  category       String
  unit           String
  unitPrice      Float
  coverage       Float
  wastePct       Float
  currency       String    @default("AED")
  supplier       String?
  notes          String?
  imageUrl       String?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime? @db.Timestamptz(6)

  organization   Organization            @relation(fields: [organizationId], references: [id])
  supplierPrices MaterialSupplierPrice[]
  priceSnapshots PriceSnapshot[]

  @@index([organizationId, name])
  @@index([organizationId, category])
  @@map("materials")
}

// ---------------------------------------------------------------------------
// Supplier intelligence (8B) — kept per ADR-009. NEW: `creditLimitAed`.
// ---------------------------------------------------------------------------

model Supplier {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  country        String?
  contactName    String?
  email          String?
  phone          String?
  website        String?
  paymentTerms   String?
  leadTimeDays   Int?
  rating         Float?
  preferred      Boolean   @default(false)
  notes          String?
  // ADR-009 addition — original requirements field that was missing in 8B.
  creditLimitAed Decimal?  @db.Decimal(14, 2)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime? @db.Timestamptz(6)

  organization   Organization            @relation(fields: [organizationId], references: [id])
  materialPrices MaterialSupplierPrice[]
  priceSnapshots PriceSnapshot[]

  @@index([organizationId])
  @@index([organizationId, name])
  @@index([organizationId, preferred])
  @@map("suppliers")
}

model MaterialSupplierPrice {
  id                   String    @id @default(cuid())
  organizationId       String
  materialId           String
  supplierId           String
  unitPrice            Float
  currency             String
  minimumOrderQuantity Float?
  leadTimeDays         Int?
  effectiveDate        DateTime  @db.Timestamptz(6)
  isPreferred          Boolean   @default(false)
  notes                String?
  createdAt            DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  material     Material     @relation(fields: [materialId], references: [id])
  supplier     Supplier     @relation(fields: [supplierId], references: [id])

  @@unique([organizationId, materialId, supplierId])
  @@index([organizationId, materialId])
  @@index([organizationId, supplierId])
  @@map("material_supplier_prices")
}

model PriceSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  materialId     String
  supplierId     String
  price          Float
  currency       String
  effectiveDate  DateTime @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  material     Material     @relation(fields: [materialId], references: [id])
  supplier     Supplier     @relation(fields: [supplierId], references: [id])

  @@index([organizationId, materialId, supplierId, effectiveDate])
  @@index([organizationId, materialId, effectiveDate])
  @@map("price_snapshots")
}

// ===========================================================================
// Sprint 1 infrastructure: Job runner + usage metering
// ===========================================================================

/// Background-job table. Worker claims via UPDATE ... FOR UPDATE SKIP LOCKED.
/// Retry-with-backoff lives in code: 2^attempt × 2s, max 3 attempts.
/// Sprint 2+ wires the real handlers (INGEST / CLASSIFY / EXTRACT_* / etc.);
/// Sprint 1 ships NOOP + FORCE_FAIL handlers to prove the lifecycle.
model Job {
  id             String    @id @default(cuid())
  organizationId String
  projectId      String?
  type           String
  payload        Json
  status         String    @default("QUEUED")
  attempts       Int       @default(0)
  error          String?
  result         Json?
  /// When the row should next become eligible for claim. Null = immediately.
  scheduledFor   DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  startedAt      DateTime? @db.Timestamptz(6)
  finishedAt     DateTime? @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([status, scheduledFor, createdAt])
  @@index([organizationId, createdAt])
  @@map("jobs")
}

/// Per-org metering. Incremented from job handlers (Sprint 2+). Single row
/// per org maintained by upsert.
model Usage {
  id             String   @id @default(cuid())
  organizationId String   @unique
  pagesProcessed Int      @default(0)
  jobsRun        Int      @default(0)
  jobsFailed     Int      @default(0)
  tokensIn       Int      @default(0)
  tokensOut      Int      @default(0)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("usages")
}

// ===========================================================================
// Sprint 2 — Takeoff pipeline (Document → Sheet → TakeoffItem)
// ===========================================================================

/// Uploaded source drawing PDF. `storageKey` is the BlobStore key under
/// org/{orgId}/projects/{projectId}/documents/{docId}/source.pdf — identical
/// shape across fs and (Sprint-3+) S3 drivers, so a dev blob is portable.
model Document {
  id             String         @id @default(cuid())
  organizationId String
  projectId      String
  filename       String
  storageKey     String
  pageCount      Int?
  status         DocumentStatus @default(UPLOADED)
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?      @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  sheets       Sheet[]

  @@index([organizationId, projectId])
  @@index([organizationId, status])
  @@map("documents")
}

/// One row per PDF page. CLASSIFY writes `discipline / sheetType / drawingNo
/// / title / scaleNote / aiJson / promptVersion`. EXTRACT_* reads them.
model Sheet {
  id             String   @id @default(cuid())
  organizationId String
  documentId     String
  pageNo         Int
  drawingNo      String?
  title          String?
  /// 'ARCH' | 'ID' | 'STR' | 'MEP' | 'UNKNOWN'
  discipline     String?
  /// 'cover' | 'register' | 'plan' | 'elevation' | 'section' | 'schedule' |
  /// 'legend' | 'detail' | 'rcp' | 'finish_plan' | 'other'
  sheetType      String?
  scaleNote      String?
  hasTextLayer   Boolean  @default(false)
  /// BlobStore key for the per-page pdftotext output. Null = scanned page.
  rawTextKey     String?
  /// BlobStore key for the per-page jpeg render. Null until INGEST runs.
  imageKey       String?
  aiJson         Json?
  promptVersion  String?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)

  organization Organization  @relation(fields: [organizationId], references: [id])
  document     Document      @relation(fields: [documentId], references: [id])
  takeoffItems TakeoffItem[]

  @@unique([documentId, pageNo])
  @@index([organizationId, documentId])
  @@index([organizationId, discipline])
  @@map("sheets")
}

/// The output of the extract pipeline. One row per measured / inferred item.
/// `qtyAi` is the AI's number (never mutated after write). `qtyFinal` is the
/// human-confirmed number; once it diverges from qtyAi a Correction row is
/// written so we can A/B retrain prompts.
model TakeoffItem {
  id             String          @id @default(cuid())
  organizationId String
  projectId      String
  category       TakeoffCategory
  tag            String?
  description    String
  unit           String
  qtyAi          Decimal?        @db.Decimal(14, 4)
  qtyFinal       Decimal?        @db.Decimal(14, 4)
  basis          TakeoffBasis
  confidence     Int             @default(0)
  sourceSheetId  String?
  sourceNote     String?
  status         TakeoffStatus   @default(AI)
  meta           Json?
  promptVersion  String?
  createdAt      DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?       @db.Timestamptz(6)

  organization    Organization     @relation(fields: [organizationId], references: [id])
  project         Project          @relation(fields: [projectId], references: [id])
  sourceSheet     Sheet?           @relation(fields: [sourceSheetId], references: [id])
  validationFlags ValidationFlag[]

  @@index([organizationId, projectId, category])
  @@index([organizationId, projectId, status])
  @@index([organizationId, projectId, confidence])
  @@map("takeoff_items")
}

/// Surfaces a problem that needs review. Always pinned to a project; usually
/// to a takeoff item too, but project-wide flags (MISSING_DISCIPLINE) leave
/// `takeoffItemId` null.
model ValidationFlag {
  id             String             @id @default(cuid())
  organizationId String
  projectId      String
  takeoffItemId  String?
  rule           String
  severity       ValidationSeverity
  message        String
  resolved       Boolean            @default(false)
  createdAt      DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  takeoffItem  TakeoffItem? @relation(fields: [takeoffItemId], references: [id])

  @@index([organizationId, projectId, resolved])
  @@index([organizationId, projectId, severity])
  @@map("validation_flags")
}

/// A/B record for prompt retraining. Polymorphic: `entity` + `entityId` point
/// at any tenant-scoped row (today only TakeoffItem). `aiValue`/`humanValue`
/// store both sides as strings (we don't need to math on them — we just need
/// to see them).
model Correction {
  id             String   @id @default(cuid())
  organizationId String
  entity         String
  entityId       String
  field          String
  aiValue        String?
  humanValue     String?
  reason         String?
  userId         String?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, entity, entityId])
  @@index([organizationId, createdAt])
  @@map("corrections")
}
